{
  "name": "promptflow-extension",
  "version": "0.1.0",
  "description": "Browser-level Prompt Command System",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run build:copy && npm run build:bundle",
    "build:copy": "node scripts/copy-assets.js",
    "build:bundle": "node scripts/build.js",
    "dev": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "generate-icons": "node generate-icons.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed"
  },
  "keywords": [
    "chrome-extension",
    "prompt",
    "productivity",
    "browser-extension"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "canvas": "^3.2.3",
    "esbuild": "^0.20.2",
    "rimraf": "^5.0.7",
    "sharp": "^0.35.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
