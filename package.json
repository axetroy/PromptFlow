{
  "name": "promptflow-extension",
  "version": "1.1.1",
  "private": true,
  "description": "Browser-level Prompt Command System - Quick Prompt invocation in any input field",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run build:copy && npm run build:bundle",
    "build:copy": "node scripts/copy-assets.js",
    "build:bundle": "node scripts/build.js",
    "dev": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "generate-icons": "node generate-icons.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "chrome-extension",
    "prompt",
    "productivity",
    "browser-extension"
  ],
  "author": "Axetroy <axetroy.dev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "canvas": "^3.2.3",
    "esbuild": "^0.20.2",
    "rimraf": "^5.0.7",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
